# Supabase (프로젝트 설정 > API 에서 확인)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Gemini API Key 는 더 이상 클라이언트(.env)에 두지 않는다.
# 키는 Supabase Edge Function 의 Secret 으로만 등록한다(브라우저로 노출 방지):
#   supabase secrets set GEMINI_API_KEY=<https://aistudio.google.com/app/apikey 에서 발급>
#   supabase functions deploy gemini

# 1인 전용 앱 고정 사용자 이메일/비밀번호 (선택: 자동 로그인용)
VITE_APP_EMAIL=
VITE_APP_PASSWORD=
